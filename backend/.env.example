PORT=3333
JWT_SECRET=troque-este-segredo
JWT_ISSUER=rhcorp-api
JWT_AUDIENCE=rhcorp-web
JWT_ACCESS_TTL=10m
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
TRUST_PROXY_HOPS=0

# Postgres e o padrao local. Para MySQL, use DB_CLIENT=mysql e preencha MYSQL_*.
DB_CLIENT=postgres
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=troque-esta-senha
PG_DATABASE=rhcorp
PG_POOL_MAX=10
PG_CONNECT_TIMEOUT_MS=5000
PG_IDLE_TIMEOUT_MS=30000
PG_STATEMENT_TIMEOUT_MS=30000
PG_APPLICATION_NAME=rhcorp-api
PG_SSL=false
PG_SSL_REJECT_UNAUTHORIZED=true
# PG_SSL_CA_BASE64=

SEED_ADMIN_EMAIL=admin@empresa.com
SEED_ADMIN_PASSWORD=troque-por-uma-senha-de-bootstrap-com-12-ou-mais-caracteres

# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DOCUMENT_ENCRYPTION_KEY=
SIGNATURE_PIN_SECRET=troque-este-segredo-de-pin
SECURE_STORAGE_PATH=./storage

# Chave privada PEM RSA opcional (quebras de linha como \\n). Sem ela o PDF fica
# com hash SHA-256 e status PENDENTE_CERTIFICADO, sem alegar assinatura PAdES.
PAYROLL_SIGNING_PRIVATE_KEY=

# Opcional: sincroniza rooms, presenca e eventos ATS entre multiplas instancias.
REDIS_URL=redis://localhost:6379
REQUIRE_REDIS=false
GOOGLE_CALENDAR_CLIENT_ID=
OUTLOOK_CALENDAR_CLIENT_ID=

# Segredos independentes para emissão anônima, anti-replay e isolamento do eNPS.
# Use valores aleatórios diferentes; ENPS_FEEDBACK_KEY deve ter 32 bytes em base64.
ENPS_PARTICIPATION_SECRET=
ENPS_BALLOT_SECRET=
ENPS_FINGERPRINT_SECRET=
ENPS_FEEDBACK_KEY=
# Ledger de auditoria: use segredos independentes com pelo menos 32 bytes.
AUDIT_LEDGER_SECRET=troque-por-um-segredo-hmac-forte-e-externo
AUDIT_PAYLOAD_KEY=troque-por-uma-chave-de-cifra-forte-e-independente
AUDIT_ANCHOR_PATH=./storage/audit-ledger-anchor.json
AUDIT_KEY_VERSION=1

# Uploads falham de forma fechada em producao quando este scanner nao esta configurado.
MALWARE_SCANNER_URL=
MALWARE_SCANNER_TOKEN=
MALWARE_SCANNER_TIMEOUT_MS=8000

# Worker idempotente de transicao APROVADA -> EM_GOZO -> ENCERRADA.
LEAVE_WORKER_INTERVAL_MS=300000
